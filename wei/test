#define _POSIX_C_SOURCE 200809L

#include <assert.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <sys/wait.h>

int main(void) {
    int compile_status = system("cc -Wall -Wextra -Werror -std=c11 -pedantic -o /tmp/wei_main /Users/wiseungcheol/Desktop/WEI/wei/main.c");
    assert(compile_status != -1);
    assert(WIFEXITED(compile_status));
    assert(WEXITSTATUS(compile_status) == 0);

    FILE *output = popen("printf 'hello\\n.exit\\n' | /tmp/wei_main", "r");
    char buffer[256];
    size_t used = 0;

    assert(output != NULL);

    while (fgets(buffer + used, (int) (sizeof(buffer) - used), output) != NULL) {
        used = strlen(buffer);
        if (used == sizeof(buffer) - 1) {
            break;
        }
    }

    assert(pclose(output) == 0);
    assert(strcmp(buffer, "db > Unrecognized command\ndb > ") == 0);

    return 0;
}
